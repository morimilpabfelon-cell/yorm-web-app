{
  "name": "@yorm/mobile",
  "main": "expo-router/entry",
  "version": "0.0.0",
  "dependencies": {
    "@expo/ui": "~57.0.7",
    "@yorm/contracts": "workspace:*",
    "@yorm/design-tokens": "workspace:*",
    "expo": "~57.0.7",
    "expo-constants": "~57.0.6",
    "expo-device": "~57.0.1",
    "expo-font": "~57.0.1",
    "expo-glass-effect": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.7",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "build": "expo export --platform web --output-dir dist",
    "doctor": "expo-doctor",
    "clean": "node -e \"const fs=require('node:fs'); for (const p of ['dist','.expo']) fs.rmSync(p,{recursive:true,force:true})\""
  },
  "private": true
